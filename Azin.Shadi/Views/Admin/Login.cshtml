@model Azin.Shadi.Models.ViewModels.AdminLoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta name="viewport" content="width=device-width" />
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.rtl.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="~/Content/Site-Admin.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">

    <title>ورود ادمین</title>
</head>
<body id="adminLoginBody" dir="rtl">

    <div>
        <form style="height:437px; margin-bottom:73px" class="signInAdmin container-fluid shadow" action="/admin/login" method="post" enctype="multipart/form-data" autocomplete="off">
            <table class="table">
                <tr class="text-center">
                    <td colspan="2" style="font-size:32px" class="fw-bold container">AZIN.SHADI</td>
                </tr>
                <tr>
                    <td colspan="2" style="border: 0px none white; padding-top:10px; margin-right:-10px" class="mt-5">
                        <p style="padding-right:40px;">ورود مدیر سایت</p>
                        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="bi bi-person-gear" viewBox="0 0 16 16">
                            <path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm.256 7a4.474 4.474 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10c.26 0 .507.009.74.025.226-.341.496-.65.804-.918C9.077 9.038 8.564 9 8 9c-5 0-6 3-6 4s1 1 1 1h5.256Zm3.63-4.54c.18-.613 1.048-.613 1.229 0l.043.148a.64.64 0 0 0 .921.382l.136-.074c.561-.306 1.175.308.87.869l-.075.136a.64.64 0 0 0 .382.92l.149.045c.612.18.612 1.048 0 1.229l-.15.043a.64.64 0 0 0-.38.921l.074.136c.305.561-.309 1.175-.87.87l-.136-.075a.64.64 0 0 0-.92.382l-.045.149c-.18.612-1.048.612-1.229 0l-.043-.15a.64.64 0 0 0-.921-.38l-.136.074c-.561.305-1.175-.309-.87-.87l.075-.136a.64.64 0 0 0-.382-.92l-.148-.045c-.613-.18-.613-1.048 0-1.229l.148-.043a.64.64 0 0 0 .382-.921l-.074-.136c-.306-.561.308-1.175.869-.87l.136.075a.64.64 0 0 0 .92-.382l.045-.148ZM14 12.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z" />
                        </svg>
                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="border: 0px none white; padding-top:5px; margin-right:-10px" class="justify-content-end mt-5 ">
                        <label style="font-size:12px;">سلام!<br />لطفا موبایل و رمز عبور خود را وارد کنید</label>
                    </td>
                </tr>
                <tr style="border:0px none white;">
                    <td class="pt-4">@Html.LabelFor(model => model.Mobile, htmlAttributes: new { @class = "control-label col-md-3" })</td>
                    <td class="pt-4">
                        @Html.EditorFor(model => model.Mobile, new { htmlAttributes = new { @class = "form-control mb-2" } })
                        <span style="font-size:12px; padding-bottom:-30px;">@Html.ValidationMessageFor(model => model.Mobile, null, new { @class = "text-danger" })</span>
                    </td>
                </tr>

                <tr style="border:0px none white">
                    <td class="pt-4">@Html.LabelFor(model => model.Password, htmlAttributes: new { @class = "control-label col-md-3" })</td>
                    <td class="pt-4">
                        @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control mb-2" } })
                        <span style="font-size:12px;padding-bottom:-30px">@Html.ValidationMessageFor(model => model.Password, null, new { @class = "text-danger" })</span>
                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="padding-right:25px; border: 0px none white">
                        <input type="submit" class="btn btn-danger align-items-center" style="width:380px; height:45px; font-size:20px;margin-top:15px;padding-bottom:20px;padding-bottom:10px;" value="ورود به سایت" />
                    </td>
                </tr>
            </table>
        </form>
    </div>
    <script src="~/Scripts/jquery-3.0.0.min.js"></script>
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
